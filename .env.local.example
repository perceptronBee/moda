# Supabase — proje ayarlarından (https://app.supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Site URL — auth redirect linklerinde kullanılır
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Service role (sadece server-side, ASLA NEXT_PUBLIC_ olmasın)
# Şu an kullanılmıyor ama ileride admin işlemleri için gerekebilir
# SUPABASE_SERVICE_ROLE_KEY=
