# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Site URL — auth redirect linklerinde kullanılır (Host header'a güvenmeyiz)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Affiliate API auth (production'da rastgele uzun string)
ADMIN_KEY=change_me_to_a_long_random_string_at_least_32_chars
PUBLISHER_KEYS=demo_publisher_key_2026

# Virtual Try-On — Gemini 2.5 Flash Image (Nano Banana)
# https://aistudio.google.com → Get API key
GEMINI_API_KEY=AIza...

# Service role — sadece server-side, asla NEXT_PUBLIC_ ile başlamaz
# SUPABASE_SERVICE_ROLE_KEY=
