# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Site URL — auth redirect linklerinde kullanılır (Host header'a güvenmeyiz)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Affiliate API auth (production'da rastgele uzun string)
ADMIN_KEY=change_me_to_a_long_random_string_at_least_32_chars
PUBLISHER_KEYS=demo_publisher_key_2026

# Virtual Try-On (Python FastAPI servisi — ayrı host'ta)
# vton-fastapi/ klasöründeki servis Cloud Run / Render / Railway'de deploy edilir
# GCP_PROJECT_ID, GOOGLE_APPLICATION_CREDENTIALS o servis'in env'inde
# Next sadece HTTP URL'i bilir.
VTON_API_URL=https://YOUR-VTON-SERVICE.run.app
# Python servisin route'u X-API-Token header'ı bekliyorsa:
VTON_API_TOKEN=

# Service role — sadece server-side, asla NEXT_PUBLIC_ ile başlamaz
# SUPABASE_SERVICE_ROLE_KEY=
