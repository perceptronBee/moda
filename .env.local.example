# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Site URL — auth redirect linklerinde kullanılır (Host header'a güvenmeyiz)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Affiliate API auth (production'da rastgele uzun string)
ADMIN_KEY=change_me_to_a_long_random_string_at_least_32_chars
PUBLISHER_KEYS=demo_publisher_key_2026

# Virtual Try-On — Gemini 2.5 Flash Image (Nano Banana)
# https://aistudio.google.com → Get API key
GEMINI_API_KEY=AIza...

# AI Stilist (chat) Python servisinin URL'i — Pipeline/main.py
# Lokalde:   STYLING_API_URL=http://localhost:8000   (arkadaşın laptop'unda)
# ngrok:     STYLING_API_URL=https://xxxx.ngrok-free.app
# Boş bırakılırsa /api/ai/styling-chat direkt Gemini'yi (aşağıdaki model) çağırır.
STYLING_API_URL=

# AI Stilist chat için Gemini modeli — default gemini-2.5-pro
#   gemini-2.5-pro        → en iyi reasoning (yavaş, pahalı)
#   gemini-2.5-flash      → dengeli
#   gemini-2.5-flash-lite → en hızlı
GEMINI_CHAT_MODEL=gemini-2.5-pro

# Service role — sadece server-side, asla NEXT_PUBLIC_ ile başlamaz
# SUPABASE_SERVICE_ROLE_KEY=
